# Application Configuration
APP_NAME=Cloudberry Data Management Console
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cloudberry
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
JWT_SECRET_KEY=cloudberry-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Encryption Configuration
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# HashData Lightning Configuration
HASHDATA_HOST=localhost
HASHDATA_PORT=5432
HASHDATA_DATABASE=hashdata
HASHDATA_USERNAME=gpadmin
HASHDATA_PASSWORD=

# Log Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=104857600

# CORS Configuration
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]
