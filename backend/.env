# 应用配置
APP_NAME=数据脱敏系统
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/data_masking
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis配置
REDIS_URL=redis://localhost:6379/0

# JWT配置
JWT_SECRET_KEY=data-masking-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 加密配置
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# HashData Lightning 配置
HASHDATA_HOST=localhost
HASHDATA_PORT=5432
HASHDATA_DATABASE=hashdata
HASHDATA_USERNAME=gpadmin
HASHDATA_PASSWORD=

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 文件上传配置
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=104857600

# CORS配置
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]
